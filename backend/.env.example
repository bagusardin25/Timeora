# Supabase direct database hosts are IPv6-only unless the IPv4 add-on is enabled.
# Use the Shared Pooler for local/Railway IPv4 environments.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-[region].pooler.supabase.com:5432/postgres
# Optional fallback if DATABASE_URL is direct/unresolvable:
SUPABASE_DB_PASSWORD=
SUPABASE_DB_REGION=ap-southeast-1

SUPABASE_URL=https://your-project.supabase.co
# Required for projects still issuing legacy HS256 access tokens.
# ES256/RS256 access tokens are verified against the project's public JWKS.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENROUTE_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
