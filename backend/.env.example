DATABASE_URL=postgresql://postgres:postgres@localhost:5432/timeora
# Railway: use Session Pooler (port 6543), NOT direct db.*.supabase.co
# postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Optional fallback if DATABASE_URL is direct/unresolvable:
SUPABASE_DB_PASSWORD=
SUPABASE_DB_REGION=ap-southeast-1

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENROUTE_API_KEY=
OPENAI_API_KEY=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
